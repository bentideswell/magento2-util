<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="FishPig\Util\Console\Command\Pool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="db.query" xsi:type="object">FishPig\Util\Console\Command\Db\QueryCommand</item>
                <item name="backup.db" xsi:type="object">FishPig\Util\Console\Command\Backup\DbCommand</item>
                <item name="backup.media" xsi:type="object">FishPig\Util\Console\Command\Backup\MediaCommand</item>
            </argument>
        </arguments>
    </type>
    <type name="FishPig\Util\Console\Command\Backup\DbCommand">
        <arguments>
            <argument name="tablesWithDataToExcludeFromBackup" xsi:type="array">
                <item name="log_customer" xsi:type="string">log_customer</item>
                <item name="log_quote" xsi:type="string">log_quote</item>
                <item name="log_summary" xsi:type="string">log_summary</item>
                <item name="log_summary_type" xsi:type="string">log_summary_type</item>
                <item name="log_url" xsi:type="string">log_url</item>
                <item name="log_url_info" xsi:type="string">log_url_info</item>
                <item name="log_visitor" xsi:type="string">log_visitor</item>
                <item name="log_visitor_info" xsi:type="string">log_visitor_info</item>
                <item name="log_visitor_online" xsi:type="string">log_visitor_online</item>
                <item name="report_compared_product_index" xsi:type="string">report_compared_product_index</item>
                <item name="report_event" xsi:type="string">report_event</item>
                <item name="report_viewed_product_aggregated_daily" xsi:type="string">report_viewed_product_aggregated_daily</item>
                <item name="report_viewed_product_aggregated_monthly" xsi:type="string">report_viewed_product_aggregated_monthly</item>
                <item name="report_viewed_product_aggregated_yearly" xsi:type="string">report_viewed_product_aggregated_yearly</item>
                <item name="report_viewed_product_index" xsi:type="string">report_viewed_product_index</item>
                <item name="catalogsearch_result" xsi:type="string">catalogsearch_result</item>
                <item name="catalogsearch_query" xsi:type="string">catalogsearch_query</item>
                <item name="catalogsearch_fulltext" xsi:type="string">catalogsearch_fulltext</item>
                <item name="sales_flat_quote" xsi:type="string">sales_flat_quote</item>
                <item name="sales_bestsellers_aggregated_yearly" xsi:type="string">sales_bestsellers_aggregated_yearly</item>
                <item name="sales_bestsellers_aggregated_monthly" xsi:type="string">sales_bestsellers_aggregated_monthly</item>
                <item name="sales_bestsellers_aggregated_daily" xsi:type="string">sales_bestsellers_aggregated_daily</item>
                <item name="adminnotification_inbox" xsi:type="string">adminnotification_inbox</item>
