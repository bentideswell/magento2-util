                <item name="catalog_product_index_eav_idx" xsi:type="string">catalog_product_index_eav_idx</item>
                <item name="catalog_product_index_price_idx" xsi:type="string">catalog_product_index_price_idx</item>
                <item name="cataloginventory_stock_status_idx" xsi:type="string">cataloginventory_stock_status_idx</item>
                <item name="coupon_aggregated_updated" xsi:type="string">coupon_aggregated_updated</item>
                <item name="cron_schedule" xsi:type="string">cron_schedule</item>
                <item name="customer_flowpassword" xsi:type="string">customer_flowpassword</item>
                <item name="dataflow_batch_export" xsi:type="string">dataflow_batch_export</item>
                <item name="index_event" xsi:type="string">index_event</item>
                <item name="index_process_event" xsi:type="string">index_process_event</item>
            </argument>
        </arguments>
    </type>
    <type name="FishPig\Util\Console\Command\Backup\MediaCommand">
        <arguments>
            <argument name="ignoredBackupPaths" xsi:type="array">
                <item name="catalog-product-cache" xsi:type="string">catalog/product/cache/*</item>
                <item name="fishpig-resp" xsi:type="string">fishpig/resp/*</item>
                <item name="fishpig-webp" xsi:type="string">fishpig/webp/*</item>
                <item name="fishpig-wordpress" xsi:type="string">fishpig/wordpress/*</item>
                <item name="tmp" xsi:type="string">tmp/*</item>
                <item name="htaccess-root" xsi:type="string">.htaccess</item>
                <item name="htaccess-nested" xsi:type="string">*/.htaccess</item>
            </argument>
        </arguments>
    </type>
</config>